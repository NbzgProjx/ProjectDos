def git_clone_tool(repo_url, tool_name):
    tool_path = tool_name.split('/')[-1] if '/' in tool_name else tool_name
    if os.path.exists(tool_path):
        print(f"{g}[+] {tool_name} already exists{res}")
        return True
    print(f"{y}[*] cloning {tool_name}...{res}")
    result = os.system(f"git clone --depth=1 {repo_url} {tool_path} 2>/dev/null")
    if result == 0:
        print(f"{g}[+] successfully cloned {tool_name}{res}")
        return True
    else:
        print(f"{r}[!] failed to clone {tool_name}{res}")
        return False

def run_tool(tool, target):
